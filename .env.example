# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="mysql://root:password@127.0.0.1:3306/construction_mgmt"

# JWT
JWT_SECRET="change-this-in-production-min-32-chars-2026"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-this-refresh-secret-min-32-chars-2026"
JWT_REFRESH_EXPIRES_IN="30d"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760
DOCUMENT_TRASH_RETENTION_DAYS=30

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
APP_URL="http://localhost:5173"

# Logging
LOG_LEVEL=debug

# Frontend
FRONTEND_URL="http://localhost:5173"
