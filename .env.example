# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="mysql://root:password@127.0.0.1:3306/construction_mgmt"

# JWT
JWT_SECRET="change-this-in-production-min-32-chars-2026"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-this-refresh-secret-min-32-chars-2026"
JWT_REFRESH_EXPIRES_IN="30d"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760
DOCUMENT_TRASH_RETENTION_DAYS=30

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
APP_URL="http://localhost:5173"

# Logging
LOG_LEVEL=debug

# Frontend
FRONTEND_URL="http://localhost:5173"

# AI assistant
AI_SECRET_ENCRYPTION_KEY=""
AI_PROVIDER="MOCK"
AI_OPENAI_API_KEY=""
AI_OPENAI_MODEL="gpt-5.4"
AI_OPENAI_COMPATIBLE_BASE_URL=""
AI_OPENAI_COMPATIBLE_API_KEY=""
AI_OPENAI_COMPATIBLE_MODEL="gpt-5.4"
AI_GEMINI_API_KEY=""
AI_GEMINI_MODEL="gemini-2.5-flash"
AI_OLLAMA_BASE_URL="http://localhost:11434"
AI_OLLAMA_MODEL="llama3.1"
AI_REQUEST_TIMEOUT_MS=30000
